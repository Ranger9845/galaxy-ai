# Galaxy AI - Environment Configuration
# Copy this file to .env and fill in your keys

# Eden AI API Key (get yours at https://app.edenai.run/user/settings)
EDEN_AI_KEY=your_eden_ai_key_here

# Eden AI Provider (default: openai/gpt-4o)
EDEN_AI_PROVIDER=openai/gpt-4o

# Server port (default: 3000)
PORT=3000

# Screen stream FPS (default: 2)
STREAM_FPS=2
